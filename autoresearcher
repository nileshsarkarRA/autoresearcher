# Auto-install missing Python packages
ensure_python_packages() {
    local packages=("psutil" "torch" "numpy" "pandas" "pyarrow" "tiktoken" "matplotlib")
    local missing_packages=()
    
    print_info "Pre-downloading all Python dependencies with uv..."
    
    # First, ensure uv sync runs to get all pyproject.toml dependencies
    if command -v uv &> /dev/null; then
        print_info "[PACKAGE] Running 'uv sync' to ensure venv is up-to-date..."
        if uv sync --upgrade 2>/dev/null; then
            print_status "uv sync completed"
        else
            print_warning "uv sync had issues, but continuing..."
        fi
    fi
    
    # Then install any specific packages that might be missing
    for pkg in "${packages[@]}"; do
        if ! python -c "import ${pkg}" 2>/dev/null; then
            # Map package names to pip install names
            local pip_name="$pkg"
            case "$pkg" in
                "tiktoken") pip_name="tiktoken" ;;
                *) pip_name="$pkg" ;;
            esac
            missing_packages+=("$pip_name")
            print_warning "Missing: $pkg"
        fi
    done
    
    if [ ${#missing_packages[@]} -gt 0 ]; then
        print_info "[PACKAGE] Installing missing packages via uv: ${missing_packages[@]}"
        if command -v uv &> /dev/null; then
            # Use uv pip install for better compatibility
            if uv pip install -q "${missing_packages[@]}" 2>/dev/null; then
                print_status "All missing packages installed via uv [OK]"
            else
                print_warning "Some packages could not be installed via uv, attempting fallback..."
                for pip_pkg in "${missing_packages[@]}"; do
                    if uv pip install -q "$pip_pkg" 2>/dev/null; then
                        print_status "Installed via uv: $pip_pkg"
                    else
                        print_warning "Could not install $pip_pkg (may not be critical)"
                    fi
                done
            fi
        else
            print_warning "uv not available, skipping dependency installation"
        fi
    else
        print_status "All dependencies found! [OK]"
    fi
}

# Function to ensure Ollama is running
check_and_start_ollama() {
    if ! command -v ollama &> /dev/null; then
        print_warning "Ollama not found. Install with: curl https://ollama.ai/install.sh | sh"
        return 1
    fi
    
    # Check if Ollama is already running
    if pgrep -x "ollama" > /dev/null; then
        print_status "Ollama server is already running"
        return 0
    fi
    
    # Try to start Ollama
    print_info "Starting Ollama server..."
    ollama serve > "$LOGS_DIR/ollama.log" 2>&1 &
    OLLAMA_PID=$!
    
    # Wait for Ollama to be ready (max 30 seconds)
    local max_attempts=30
    local attempt=0
    while [ $attempt -lt $max_attempts ]; do
        if ollama list > /dev/null 2>&1; then
            print_status "Ollama server started successfully"
            return 0
        fi
        sleep 1
        ((attempt++))
    done
    
    print_error "Ollama server failed to start. Check logs: cat $LOGS_DIR/ollama.log"
    kill $OLLAMA_PID 2>/dev/null || true
    return 1
}

# Function to generate graph from training logs
generate_training_graph() {
    log_msg "Generating training metrics graph..."
    
    python3 << 'PYTHON_EOF'
import json
import re
from pathlib import Path
import os
import sys
from datetime import datetime

# Ensure assets directory exists
os.makedirs('assets', exist_ok=True)

try:
    import matplotlib.pyplot as plt
    import matplotlib
    matplotlib.use('Agg')  # Non-interactive backend
except ImportError:
    print("[WARN] matplotlib not available. Skipping graph generation.")
    exit(0)

# Find the most recent training log file
logs_dir = Path("logs")
if not logs_dir.exists():
    print("[WARN] No logs directory found. Skipping graph generation.")
    exit(0)

# Find the most recent training log
log_files = sorted(logs_dir.glob("training_*.log"), reverse=True)
if not log_files:
    print("[WARN] No training log found in logs/ directory. Skipping graph generation.")
    exit(0)

log_file = log_files[0]
print(f"[INFO] Parsing log file: {log_file}")

steps = []
losses = []
mfus = []
throughputs = []
remainings = []

with open(log_file, 'r') as f:
    for line in f:
        # Parse: step 00245 | loss: 3.456 | lrm: 1.00 | dt: 1000ms | tok/sec: 135,454 | mfu: 2.2% | epoch: 1 | remaining: 500s
        # Only parse lines with "step" keyword
        if 'step ' not in line:
            continue
        
        step_match = re.search(r'step (\d+)', line)
        loss_match = re.search(r'loss: ([\d.]+)', line)
        mfu_match = re.search(r'mfu: ([\d.]+)%', line)
        tps_match = re.search(r'tok/sec: ([\d,]+)', line)
        remaining_match = re.search(r'remaining: (\d+)s', line)
        
        if step_match and loss_match:
            steps.append(int(step_match.group(1)))
            losses.append(float(loss_match.group(1)))
            
            if mfu_match:
                mfus.append(float(mfu_match.group(1)))
            else:
                mfus.append(0)
            
            if tps_match:
                # Remove commas from throughput (e.g., "135,454" -> 135454)
                tok_sec_str = tps_match.group(1).replace(',', '')
                throughputs.append(float(tok_sec_str) / 1000)  # Convert to millions
            else:
                throughputs.append(0)
            
            if remaining_match:
                remainings.append(int(remaining_match.group(1)))

if not steps or len(steps) < 2:
    print(f"[WARN] Insufficient data: found {len(steps)} steps. Need at least 2. Skipping graph generation.")
    exit(0)

print(f"[OK] Parsed {len(steps)} training steps")

# Create figure with subplots
fig, axes = plt.subplots(2, 2, figsize=(14, 10))
fig.suptitle(f'AutoResearcher Training Metrics - {len(steps)} Steps', fontsize=16, fontweight='bold')

# Plot 1: Loss curve
ax = axes[0, 0]
ax.plot(steps, losses, 'b-', linewidth=2.5, marker='o', markersize=4, label='Loss')
ax.set_xlabel('Step', fontsize=11)
ax.set_ylabel('Loss (BPB)', color='b', fontsize=11)
ax.tick_params(axis='y', labelcolor='b')
ax.grid(True, alpha=0.3, linestyle='--')
ax.set_title('Training Loss Curve', fontsize=12, fontweight='bold')
# Add loss improvement annotation
if len(losses) > 1:
    improvement = ((losses[0] - losses[-1]) / losses[0] * 100)
    ax.text(0.98, 0.95, f'↓ {improvement:.1f}%', transform=ax.transAxes, 
            fontsize=11, verticalalignment='top', horizontalalignment='right',
            bbox=dict(boxstyle='round', facecolor='lightblue', alpha=0.7))

# Plot 2: Model FLOPs Utilization
if mfus and any(m > 0 for m in mfus):
    ax = axes[0, 1]
    ax.plot(steps, mfus, 'g-', linewidth=2.5, marker='s', markersize=4, label='MFU')
    ax.set_xlabel('Step', fontsize=11)
    ax.set_ylabel('MFU (%)', color='g', fontsize=11)
    ax.tick_params(axis='y', labelcolor='g')
    ax.grid(True, alpha=0.3, linestyle='--')
    ax.set_ylim([0, max(mfus) * 1.1 if max(mfus) > 0 else 10])
    ax.set_title('Model FLOPs Utilization', fontsize=12, fontweight='bold')
    # Add max MFU annotation
    max_mfu = max(mfus)
    if max_mfu > 0:
        ax.text(0.98, 0.95, f'Max: {max_mfu:.1f}%', transform=ax.transAxes,
                fontsize=11, verticalalignment='top', horizontalalignment='right',
                bbox=dict(boxstyle='round', facecolor='lightgreen', alpha=0.7))
else:
    ax = axes[0, 1]
    ax.text(0.5, 0.5, 'MFU Data\nNot Available', ha='center', va='center', fontsize=14)
    ax.axis('off')

# Plot 3: Throughput
if throughputs and any(t > 0 for t in throughputs):
    ax = axes[1, 0]
    ax.plot(steps, throughputs, 'r-', linewidth=2.5, marker='^', markersize=4, label='Throughput')
    ax.set_xlabel('Step', fontsize=11)
    ax.set_ylabel('Throughput (M tok/sec)', color='r', fontsize=11)
    ax.tick_params(axis='y', labelcolor='r')
    ax.grid(True, alpha=0.3, linestyle='--')
    ax.set_title('Training Throughput', fontsize=12, fontweight='bold')
    # Add average throughput annotation
    avg_tps = sum(throughputs) / len(throughputs)
    if avg_tps > 0:
        ax.text(0.98, 0.95, f'Avg: {avg_tps:.1f}M', transform=ax.transAxes,
                fontsize=11, verticalalignment='top', horizontalalignment='right',
                bbox=dict(boxstyle='round', facecolor='lightcoral', alpha=0.7))
else:
    ax = axes[1, 0]
    ax.text(0.5, 0.5, 'Throughput Data\nNot Available', ha='center', va='center', fontsize=14)
    ax.axis('off')

# Plot 4: Summary statistics
ax = axes[1, 1]
ax.axis('off')

summary_text = f"""
╔═══════════════════════════════════════════╗
║     TRAINING SUMMARY STATISTICS           ║
╚═══════════════════════════════════════════╝

Total Steps:           {len(steps):,}
Initial Loss:          {losses[0]:.4f} BPB
Final Loss:            {losses[-1]:.4f} BPB

Loss Improvement:      ↓ {((losses[0] - losses[-1]) / losses[0] * 100):.1f}%

Avg MFU:               {sum(mfus) / len(mfus):.1f}%
Peak MFU:              {max(mfus):.1f}%

Avg Throughput:        {sum(throughputs) / len(throughputs):.1f}M tok/sec
Peak Throughput:       {max(throughputs):.1f}M tok/sec

Time Budget Remaining: {remainings[-1] if remainings else 'N/A'}s
"""

ax.text(0.05, 0.95, summary_text, transform=ax.transAxes, fontsize=10, 
        verticalalignment='top', family='monospace',
        bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.8, pad=1))

plt.tight_layout()

# Save to assets folder with timestamp
timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
output_file = f'assets/training_metrics_{timestamp}.png'
try:
    plt.savefig(output_file, dpi=120, bbox_inches='tight', facecolor='white')
    print(f"[OK] Graph saved as: {output_file}")
except Exception as e:
    print(f"[ERR] Error saving graph: {e}")
    exit(1)

# Also save latest copy
try:
    plt.savefig('assets/training_metrics_latest.png', dpi=120, bbox_inches='tight', facecolor='white')
    print(f"[OK] Latest graph updated: assets/training_metrics_latest.png")
except Exception as e:
    print(f"[ERR] Error saving latest graph: {e}")

plt.close()
print("[OK] Graph generation complete!")

PYTHON_EOF
}

