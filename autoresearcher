# Auto-install missing Python packages
ensure_python_packages() {
    local packages=("psutil" "torch" "numpy" "pandas" "pyarrow" "tiktoken" "matplotlib")
    local missing_packages=()
    
    print_info "🔍 Pre-downloading all Python dependencies with uv..."
    
    # First, ensure uv sync runs to get all pyproject.toml dependencies
    if command -v uv &> /dev/null; then
        print_info "📦 Running 'uv sync' to ensure venv is up-to-date..."
        if uv sync --upgrade 2>/dev/null; then
            print_status "uv sync completed"
        else
            print_warning "uv sync had issues, but continuing..."
        fi
    fi
    
    # Then install any specific packages that might be missing
    for pkg in "${packages[@]}"; do
        if ! python -c "import ${pkg}" 2>/dev/null; then
            # Map package names to pip install names
            local pip_name="$pkg"
            case "$pkg" in
                "tiktoken") pip_name="tiktoken" ;;
                *) pip_name="$pkg" ;;
            esac
            missing_packages+=("$pip_name")
            print_warning "Missing: $pkg"
        fi
    done
    
    if [ ${#missing_packages[@]} -gt 0 ]; then
        print_info "📦 Installing missing packages via uv: ${missing_packages[@]}"
        if command -v uv &> /dev/null; then
            # Use uv pip install for better compatibility
            if uv pip install -q "${missing_packages[@]}" 2>/dev/null; then
                print_status "All missing packages installed via uv ✓"
            else
                print_warning "Some packages could not be installed via uv, attempting fallback..."
                for pip_pkg in "${missing_packages[@]}"; do
                    if uv pip install -q "$pip_pkg" 2>/dev/null; then
                        print_status "Installed via uv: $pip_pkg"
                    else
                        print_warning "Could not install $pip_pkg (may not be critical)"
                    fi
                done
            fi
        else
            print_warning "uv not available, skipping dependency installation"
        fi
    else
        print_status "All dependencies found! ✓"
    fi
}

# Function to ensure Ollama is running
check_and_start_ollama() {
    if ! command -v ollama &> /dev/null; then
        print_warning "Ollama not found. Install with: curl https://ollama.ai/install.sh | sh"
        return 1
    fi
    
    # Check if Ollama is already running
    if pgrep -x "ollama" > /dev/null; then
        print_status "Ollama server is already running"
        return 0
    fi
    
    # Try to start Ollama
    print_info "Starting Ollama server..."
    ollama serve > "$LOGS_DIR/ollama.log" 2>&1 &
    OLLAMA_PID=$!
    
    # Wait for Ollama to be ready (max 30 seconds)
    local max_attempts=30
    local attempt=0
    while [ $attempt -lt $max_attempts ]; do
        if ollama list > /dev/null 2>&1; then
            print_status "Ollama server started successfully"
            return 0
        fi
        sleep 1
        ((attempt++))
    done
    
    print_error "Ollama server failed to start. Check logs: cat $LOGS_DIR/ollama.log"
    kill $OLLAMA_PID 2>/dev/null || true
    return 1
}

# Function to generate graph from training logs
generate_training_graph() {
