print_header "[CONFIG] Configuration Summary"
echo -e "${WHITE}[TIME] TRAINING:${NC}"
echo -e "  Duration:  ${CYAN}$(format_time $((TRAINING_MINUTES * 60)))${NC}  (+ 10s auto-buffer)"
if [ "$SETUP_DEEPSEEK" = true ]; then
    echo -e "  DeepSeek Feedback: ${CYAN}$(format_time $((IMPROVE_INTERVAL_MINUTES * 60)))${NC} interval"
fi
echo ""
echo -e "${WHITE}[DATA] DATASET:${NC}"
echo -e "  Dataset: ${CYAN}$DATASET${NC}"
echo -e "  Shards:  ${CYAN}$NUM_SHARDS${NC}"
echo -e "  Workers: ${CYAN}$WORKERS${NC}"
echo ""
echo -e "${WHITE}[AI] INTEGRATIONS:${NC}"
if [ "$SETUP_DEEPSEEK" = true ]; then
    echo -e "  DeepSeek Coder: ${GREEN}Enabled${NC} (feedback every $(format_time $((IMPROVE_INTERVAL_MINUTES * 60))))"
else
    echo -e "  DeepSeek Coder: ${YELLOW}Disabled${NC}"
fi
echo ""

read -p "$(echo -e "${MAGENTA}[?]${NC} Start training pipeline? (y/n) [default: y]: ")" START_CHOICE
START_CHOICE=${START_CHOICE:-y}
if [[ ! "$START_CHOICE" =~ ^[yY]$ ]]; then
    print_warning "Pipeline cancelled."
    exit 0
fi

# ============================================================================
# AUTO-INSTALL MISSING DEPENDENCIES
# ============================================================================
ensure_python_packages

# ============================================================================
# HARDWARE PROFILE DETECTION
# ============================================================================
print_header "[GPU] Hardware Profile Detection"

HARDWARE_PROFILE="GENERIC"
DETECTED_GPU="Unknown"
DETECTED_VRAM=0

# Detect GPU via Python
GPU_DETECT_OUTPUT=$(python3 - <<'PYEOF' 2>/dev/null
import sys
try:
    import torch
    if not torch.cuda.is_available():
        print("NOGPU|No GPU detected|0")
        sys.exit(0)
    name  = torch.cuda.get_device_name(0)
    vram  = torch.cuda.get_device_properties(0).total_memory / 1024**3
    print(f"GPU|{name}|{vram:.1f}")
except Exception as e:
    print(f"ERROR|{e}|0")
PYEOF
)

IFS='|' read -r DETECT_STATUS DETECT_NAME DETECT_VRAM <<< "$GPU_DETECT_OUTPUT"

if [ "$DETECT_STATUS" = "GPU" ]; then
    DETECTED_GPU="$DETECT_NAME"
    DETECTED_VRAM="$DETECT_VRAM"

    # Determine auto profile
    if echo "$DETECT_NAME" | grep -qi "A100" && (( $(echo "$DETECT_VRAM >= 70" | bc -l 2>/dev/null || echo 0) )); then
        AUTO_PROFILE="A100_HIGH_PERFORMANCE"
        AUTO_DESC="A100 80GB - High Performance Mode"
        AUTO_BATCH=64; AUTO_WORKERS=42; AUTO_CUDA_FRAC="0.95"; AUTO_DEPTH=8
    elif echo "$DETECT_NAME" | grep -qiE "RTX 40[6-9]0|RTX4060|RTX4070|RTX4080|RTX4090" && (( $(echo "$DETECT_VRAM <= 12" | bc -l 2>/dev/null || echo 0) )); then
        AUTO_PROFILE="RTX4060_LAPTOP"
        AUTO_DESC="RTX 4060 8GB - Laptop Mode"
        AUTO_BATCH=4; AUTO_WORKERS=4; AUTO_CUDA_FRAC="0.85"; AUTO_DEPTH=4
    else
        AUTO_PROFILE="GENERIC"
        AUTO_DESC="Generic GPU - Standard Mode"
        AUTO_BATCH=8; AUTO_WORKERS=8; AUTO_CUDA_FRAC="0.80"; AUTO_DEPTH=6
    fi

    echo ""
    echo -e "${CYAN}  Detected GPU : ${WHITE}${BOLD}$DETECTED_GPU${NC}"
    echo -e "${CYAN}  VRAM         : ${WHITE}${BOLD}${DETECTED_VRAM} GB${NC}"
    echo -e "${CYAN}  Auto Profile : ${GREEN}${BOLD}$AUTO_DESC${NC}"
    echo ""
    echo -e "${WHITE}  Profile Settings:${NC}"
    echo -e "    Depth           : ${CYAN}$AUTO_DEPTH${NC} layers"
    echo -e "    Batch Size      : ${CYAN}$AUTO_BATCH${NC}"
    echo -e "    Workers         : ${CYAN}$AUTO_WORKERS${NC}"
    echo -e "    CUDA Memory     : ${CYAN}$(echo "$AUTO_CUDA_FRAC * 100" | bc)%${NC}"
    echo ""
    echo -e "${WHITE}  Select profile to use:${NC}"
    echo -e "    ${MAGENTA}1${NC}. Accept detected  ->  ${GREEN}$AUTO_DESC${NC}  ${WHITE}[DEFAULT]${NC}"
    echo -e "    ${MAGENTA}2${NC}. Force A100 80GB  ->  High Performance Mode"
    echo -e "    ${MAGENTA}3${NC}. Force RTX 4060   ->  Laptop 8GB Mode"
    echo -e "    ${MAGENTA}4${NC}. Force Generic    ->  Standard Mode"
    echo ""
    read -p "$(echo -e "${MAGENTA}[?]${NC} Choose profile (1-4) [default: 1]: ")" HW_CHOICE
    HW_CHOICE=${HW_CHOICE:-1}

    case $HW_CHOICE in
        1)
            HARDWARE_PROFILE="$AUTO_PROFILE"
            HW_BATCH=$AUTO_BATCH; HW_WORKERS=$AUTO_WORKERS; HW_CUDA_FRAC=$AUTO_CUDA_FRAC; HW_DEPTH=$AUTO_DEPTH
            HW_DESC="$AUTO_DESC"
            ;;
        2)
            HARDWARE_PROFILE="A100_HIGH_PERFORMANCE"
            HW_BATCH=64; HW_WORKERS=42; HW_CUDA_FRAC="0.95"; HW_DEPTH=8
            HW_DESC="A100 80GB - High Performance Mode"
            ;;
        3)
            HARDWARE_PROFILE="RTX4060_LAPTOP"
            HW_BATCH=4; HW_WORKERS=4; HW_CUDA_FRAC="0.85"; HW_DEPTH=4
            HW_DESC="RTX 4060 8GB - Laptop Mode"
            ;;
        4)
            HARDWARE_PROFILE="GENERIC"
            HW_BATCH=8; HW_WORKERS=8; HW_CUDA_FRAC="0.80"; HW_DEPTH=6
            HW_DESC="Generic GPU - Standard Mode"
            ;;
        *)
            HARDWARE_PROFILE="$AUTO_PROFILE"
            HW_BATCH=$AUTO_BATCH; HW_WORKERS=$AUTO_WORKERS; HW_CUDA_FRAC=$AUTO_CUDA_FRAC; HW_DEPTH=$AUTO_DEPTH
            HW_DESC="$AUTO_DESC"
            ;;
    esac

    # Override workers from hardware profile (unless user already set manually)
    WORKERS=$HW_WORKERS

    print_status "Profile confirmed: ${BOLD}$HW_DESC${NC}"
    echo -e "  ${WHITE}Depth${NC}: ${CYAN}$HW_DEPTH${NC}  |  ${WHITE}Batch${NC}: ${CYAN}$HW_BATCH${NC}  |  ${WHITE}Workers${NC}: ${CYAN}$HW_WORKERS${NC}  |  ${WHITE}CUDA mem${NC}: ${CYAN}$(echo "$HW_CUDA_FRAC * 100" | bc)%${NC}"

else
    print_warning "GPU detection failed ($DETECT_NAME). Using GENERIC profile."
    HARDWARE_PROFILE="GENERIC"
    HW_BATCH=8; HW_WORKERS=8; HW_CUDA_FRAC="0.80"; HW_DEPTH=6
    HW_DESC="Generic GPU - Standard Mode"
fi

# Export profile so train.py and setup_a100.py can read it
export HARDWARE_PROFILE="$HARDWARE_PROFILE"
export CUDA_MEMORY_FRACTION="$HW_CUDA_FRAC"
echo ""

# ============================================================================
# STEP 1: Hardware Verification
# ============================================================================
print_header "[CHECK] Step 1/4: Hardware Verification"
STEP1_START=$(date +%s)

if HARDWARE_PROFILE="$HARDWARE_PROFILE" python setup_a100.py; then
    print_status "Hardware verification passed!"
    STEP1_TIME=$(($(date +%s) - STEP1_START))
else
    print_error "Hardware verification failed!"
    print_info "Please fix the issues shown above and try again."
    exit 1
fi

# ============================================================================
# STEP 2: Data Preparation
# ============================================================================
print_header "[DATA] Step 2/4: Data Preparation ($DATASET)"
STEP2_START=$(date +%s)

print_info "Downloading $NUM_SHARDS shards with $WORKERS parallel workers..."
print_info "Dataset: $DATASET"
echo ""

if python prepare.py \
    --dataset "$DATASET" \
    --num-shards "$NUM_SHARDS" \
    --download-workers "$WORKERS"; then
    print_status "Data preparation completed!"
    STEP2_TIME=$(($(date +%s) - STEP2_START))
else
    print_error "Data preparation failed!"
    exit 1
fi

# ============================================================================
# STEP 3: DeepSeek Setup (Optional)
# ============================================================================
if [ "$SETUP_DEEPSEEK" = true ]; then
    print_header "[AI] Step 3/4: DeepSeek Coder Integration Setup"
    STEP3_START=$(date +%s)
    
    print_info "Ensuring Ollama is running..."
    if check_and_start_ollama; then
        print_status "Ollama ready!"
        print_info "Checking DeepSeek model: $DEEPSEEK_MODEL"
        echo ""
        
        # Check if model already exists
        if ollama list | grep -q "deepseek-coder"; then
            print_status "DeepSeek model already available!"
        else
            print_info "Downloading DeepSeek model: $DEEPSEEK_MODEL"
            if ollama pull "$DEEPSEEK_MODEL"; then
                print_status "DeepSeek model downloaded successfully!"
            else
                print_warning "Failed to download DeepSeek model"
            fi
        fi
        
        echo ""
        print_status "DeepSeek integration ready!"
    else
        print_warning "Ollama setup failed. DeepSeek integration skipped."
    fi
    
    STEP3_TIME=$(($(date +%s) - STEP3_START))
    STEP_COUNT=4
else
    STEP3_TIME=0
    STEP_COUNT=3
fi

# ============================================================================
# STEP 4/3: Training with Timer
# ============================================================================
TRAINING_STEP=$((STEP_COUNT))
print_header "[TRAIN] Step $TRAINING_STEP/$STEP_COUNT: Starting Training ($(format_time $((TRAINING_MINUTES * 60))))"

TRAINING_START=$(date +%s)
TRAINING_LIMIT_SECONDS=$((TRAINING_MINUTES * 60))

echo -e "${WHITE}[CONFIG] Training Configuration:${NC}"
echo -e "  [TIME] Time Limit  : ${CYAN}$(format_time $TRAINING_LIMIT_SECONDS)${NC}  (+10s auto-buffer)"
echo -e "  [GPU]  Profile     : ${CYAN}${HW_DESC:-$HARDWARE_PROFILE}${NC}"
echo -e "  [STOP] Auto-stop   : ${CYAN}Enabled${NC}"
echo -e "  [LOG]  Log File    : ${CYAN}$TRAINING_LOG${NC}"
echo ""
print_info "Starting training... (will auto-stop at time limit)"
echo ""

log_msg "========== TRAINING START =========="
log_msg "Duration: $(format_time $TRAINING_LIMIT_SECONDS)"
log_msg "Hardware Profile: ${HW_DESC:-$HARDWARE_PROFILE}"
log_msg "Dataset: $DATASET"
log_msg "Shards: $NUM_SHARDS"
log_msg "Workers: $WORKERS"
log_msg "===================================="

# Pre-training dependency check and auto-install
print_info "Pre-training dependency check..."
ensure_python_packages

# Calculate time budget in seconds (wall-clock training time, excluding startup)
# This is the actual training duration (not including data prep, model building, etc)
TIME_BUDGET_SECONDS=$((TRAINING_MINUTES * 60))

# Start training with configured time budget and capture output
if command -v uv >/dev/null 2>&1; then
    log_msg "Using 'uv' runner to start training (TIME_BUDGET=${TIME_BUDGET_SECONDS}s)"
    export TIME_BUDGET_SECONDS=$TIME_BUDGET_SECONDS
    uv run train.py 2>&1 | tee -a "$TRAINING_LOG" &
    TRAIN_PID=$!
else
    log_msg "Warning: 'uv' runner not found; falling back to 'python -u train.py'"
    # Run train.py directly with unbuffered output so logs flush in real time
    export TIME_BUDGET_SECONDS=$TIME_BUDGET_SECONDS
    python3 -u train.py 2>&1 | tee -a "$TRAINING_LOG" &
    TRAIN_PID=$!
fi

# Wait for actual training to start (skip setup/download time)
print_info "Waiting for training to initialize..."
TRAINING_STARTED=false
for i in {1..120}; do
    if grep -q "step 00000" "$TRAINING_LOG" 2>/dev/null; then
        TRAINING_STARTED=true
        # Reset timer AFTER training actually starts (skip all download time)
        TRAINING_START=$(date +%s)
        log_msg "[OK] Training initialization complete, timer started"
        echo ""
        break
    fi
    sleep 0.5
done

if [ "$TRAINING_STARTED" = false ]; then
    print_warning "Training initialization timeout"
fi

# Monitor training with live metrics refresh every 5 seconds
LAST_REPORT=0
LAST_LINES=0
while kill -0 $TRAIN_PID 2>/dev/null; do
    CURRENT=$(date +%s)
    ELAPSED=$((CURRENT - TRAINING_START))
    REMAINING=$((TRAINING_LIMIT_SECONDS - ELAPSED))
    
    if [ $REMAINING -le 0 ]; then
        print_error "Time limit reached. Stopping training..."
        log_msg "[TIME] TIME LIMIT REACHED - Stopping training"
        kill $TRAIN_PID 2>/dev/null || true
        wait $TRAIN_PID 2>/dev/null || true
        break
    fi
    
    # Refresh metrics every 5 seconds
    if [ $((ELAPSED - LAST_REPORT)) -ge 5 ] || [ $LAST_REPORT -eq 0 ]; then
        clear
        echo -e "${CYAN}╔════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${CYAN}║          TRAINING IN PROGRESS - LIVE METRICS               ║${NC}"
        echo -e "${CYAN}╚════════════════════════════════════════════════════════════╝${NC}"
        echo ""
        
        # Display time progress
        echo -e "${WHITE}[TIME] Training Progress:${NC}"
        echo -e "  Elapsed: ${CYAN}$(format_time $ELAPSED)${NC} | Remaining: ${MAGENTA}$(format_time $REMAINING)${NC}"
        PROGRESS=$((ELAPSED * 100 / TRAINING_LIMIT_SECONDS))
        echo -e "  Progress: ${CYAN}[$(printf '#%.0s' $(seq 1 $((PROGRESS / 5))))$(printf '░%.0s' $(seq 1 $((20 - PROGRESS / 5))))${NC}] ${CYAN}${PROGRESS}%${NC}"
        echo ""
        
        # Display latest metrics from training
        if [ -f "$TRAINING_LOG" ]; then
            echo -e "${WHITE}[METRICS] Latest Training Metrics:${NC}"
            # Get last line with step/loss info
            LAST_STEP=$(tail -50 "$TRAINING_LOG" 2>/dev/null | grep "step " | tail -1 || echo "")
            if [ ! -z "$LAST_STEP" ]; then
                echo -e "  ${CYAN}$LAST_STEP${NC}"
            fi
            
            # Extract and display individual metrics if available
            echo ""
            echo -e "${WHITE}[STATS] Detailed Metrics:${NC}"
            LAST_LOSS=$(tail -50 "$TRAINING_LOG" 2>/dev/null | grep -oP 'loss: \K[0-9.]+' | tail -1 || echo "-")
            LAST_MFU=$(tail -50 "$TRAINING_LOG" 2>/dev/null | grep -oP 'mfu: \K[0-9.]+' | tail -1 || echo "-")
            LAST_LRM=$(tail -50 "$TRAINING_LOG" 2>/dev/null | grep -oP 'lrm: \K[0-9.]+' | tail -1 || echo "-")
            LAST_TOK=$(tail -50 "$TRAINING_LOG" 2>/dev/null | grep -oP 'tok/sec: \K[0-9,]+' | tail -1 || echo "-")
            LAST_EPOCH=$(tail -50 "$TRAINING_LOG" 2>/dev/null | grep -oP 'epoch: \K[0-9]' | tail -1 || echo "-")
            
            echo -e "  Loss (BPB):        ${MAGENTA}$LAST_LOSS${NC}"
            echo -e "  MFU (%):           ${GREEN}$LAST_MFU${NC}"
            echo -e "  LR Multiplier:     ${CYAN}$LAST_LRM${NC}"
            echo -e "  Tokens/sec:        ${YELLOW}$LAST_TOK${NC}"
            echo -e "  Epoch:             ${BLUE}$LAST_EPOCH${NC}"
        fi
        
        echo ""
        echo -e "${MAGENTA}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        LAST_REPORT=$ELAPSED
    fi
    
    sleep 1
done
echo ""
echo ""

TRAINING_TIME=$(($(date +%s) - TRAINING_START))
log_msg "========== TRAINING COMPLETE =========="
log_msg "Total training time: $(format_time $TRAINING_TIME)"
log_msg "========================================"

# ============================================================================
# Final Summary
# ============================================================================
TOTAL_TIME=$(($(date +%s) - OVERALL_START))

print_header "[DONE] Pipeline Complete"

echo -e "${WHITE}[TIME] Timing Summary:${NC}"
echo -e "  [CHECK] Hardware Verification : ${CYAN}$(format_time $STEP1_TIME)${NC}"
echo -e "  [DATA]  Data Preparation      : ${CYAN}$(format_time $STEP2_TIME)${NC}"
if [ "$SETUP_DEEPSEEK" = true ]; then
    echo -e "  [AI]    DeepSeek Setup        : ${CYAN}$(format_time $STEP3_TIME)${NC}"
fi
echo -e "  [TRAIN] Training              : ${CYAN}$(format_time $TRAINING_TIME)${NC}"
echo -e "  ${MAGENTA}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "  [TOTAL] Pipeline Time         : ${MAGENTA}$(format_time $TOTAL_TIME)${NC}"
echo ""

print_status "Training completed successfully!"
echo -e "${GREEN}Log file: $TRAINING_LOG${NC}"

# Generate graph from logs
print_info "Generating training metrics graph from logs..."
generate_training_graph

if [ -f "assets/training_metrics_latest.png" ]; then
    log_msg "Training metrics graph generated: assets/training_metrics_latest.png"
else
    log_msg "No metrics graph produced (no step/loss lines found in log)"
fi

print_header "[RESULTS] Output Files & Analysis"

echo -e "${WHITE}[FILES] Output Files Generated:${NC}"
echo -e "  [LOG]   Training Log:"
echo -e "          ${CYAN}$TRAINING_LOG${NC}"
echo -e "          Complete training log with all metrics"
echo ""
echo -e "  [GRAPH] Metrics Graph (main output):"
echo -e "          ${GREEN}assets/training_metrics_latest.png${NC}"
echo -e "          4-subplot graph: loss, MFU, throughput, summary"
echo ""
echo -e "  [DOCS]  Graph Documentation:"
echo -e "          ${CYAN}assets/README.md${NC}"
echo -e "          Detailed info about graphs and how to use them"
echo ""

# Show final metrics from log
if [ -f "$TRAINING_LOG" ]; then
    echo -e "${WHITE}[METRICS] Final Training Metrics:${NC}"
    tail -15 "$TRAINING_LOG" | grep -E "(val_bpb|loss|mfu|tokens|seconds)" || echo "  (View full log for details: cat $TRAINING_LOG)"
fi
echo ""

echo -e "${MAGENTA}[NEXT] Next Steps:${NC}"
echo -e "  View metrics graph  : ${CYAN}open assets/training_metrics_latest.png${NC}"
echo -e "  View assets folder  : ${CYAN}open assets/${NC}"
echo -e "  View full log       : ${CYAN}cat $TRAINING_LOG${NC}"
echo -e "  View graph docs     : ${CYAN}cat assets/README.md${NC}"
echo -e "  Try different data  : ${CYAN}./autoresearcher --dataset arxiv${NC}"
echo -e "  Increase training   : ${CYAN}./autoresearcher --hours 2${NC}"
echo -e "  View help           : ${CYAN}./autoresearcher --help${NC}"
echo ""

print_status "Pipeline complete! Check assets/training_metrics_latest.png for your graph."
echo ""
